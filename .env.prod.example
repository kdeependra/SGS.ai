# ──────────────────────────────────────────────────
# SGS.ai Production Environment Configuration
# Copy this file to .env.prod and fill in the values
# ──────────────────────────────────────────────────

# ── Required secrets ──────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_strong_password
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────
AUTH_DB_USER=root
AUTH_DB_NAME=metadatamgmt

# ── Ports (change to avoid conflicts) ────────────
MYSQL_PORT=3306
REDIS_PORT=6379
HDF5_PORT=5000
MCP_PORT=8001
BACKEND_PORT=8000
FRONTEND_PORT=3000
